{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/sendEmail.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/sendEmail",
      "dest": "/api/sendEmail.ts"
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}